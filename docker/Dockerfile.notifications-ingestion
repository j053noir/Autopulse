FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy csproj files and restore dependencies
COPY ["AutoPulse.Notifications/AutoPulse.Notifications.Ingestion/AutoPulse.Notifications.Ingestion.csproj", "AutoPulse.Notifications/AutoPulse.Notifications.Ingestion/"]
COPY ["AutoPulse.Notifications/AutoPulse.Notifications.Shared/AutoPulse.Notifications.Shared.csproj", "AutoPulse.Notifications/AutoPulse.Notifications.Shared/"]

RUN dotnet restore "AutoPulse.Notifications/AutoPulse.Notifications.Ingestion/AutoPulse.Notifications.Ingestion.csproj"

# Copy the rest of the source code
COPY . .

# Build and publish the Ingestion API (disabling AOT inside Docker if prerequisites like clang are missing)
WORKDIR "/src/AutoPulse.Notifications/AutoPulse.Notifications.Ingestion"
RUN dotnet publish "AutoPulse.Notifications.Ingestion.csproj" -c Release -o /app/publish /p:UseAppHost=false /p:PublishAot=false

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "AutoPulse.Notifications.Ingestion.dll"]
